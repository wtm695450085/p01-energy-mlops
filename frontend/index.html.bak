<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Prognoza Cen Energii RDN — Polska</title>
  <meta name="description" content="Inteligentna prognoza godzinowych cen energii elektrycznej na Rynku Dnia Następnego w Polsce. Kliknij, by uzyskać 24 prognozy na jutro." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    :root {
      --bg-primary:    #0a0e1a;
      --bg-secondary:  #111827;
      --bg-card:       rgba(255,255,255,0.04);
      --bg-glass:      rgba(255,255,255,0.06);
      --border:        rgba(255,255,255,0.08);
      --border-hover:  rgba(99,102,241,0.5);
      --accent:        #6366f1;
      --accent-light:  #818cf8;
      --accent-glow:   rgba(99,102,241,0.25);
      --success:       #10b981;
      --warning:       #f59e0b;
      --danger:        #ef4444;
      --text-primary:  #f1f5f9;
      --text-secondary:#94a3b8;
      --text-muted:    #475569;
      --gradient-1:    linear-gradient(135deg, #6366f1, #8b5cf6);
      --gradient-2:    linear-gradient(135deg, #06b6d4, #6366f1);
      --radius:        16px;
      --radius-sm:     8px;
      --shadow:        0 25px 50px rgba(0,0,0,0.5);
      --transition:    0.25s cubic-bezier(0.4,0,0.2,1);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* --- Background animated gradient --- */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 20% -10%, rgba(99,102,241,0.15) 0%, transparent 60%),
        radial-gradient(ellipse 60% 50% at 80% 110%, rgba(139,92,246,0.12) 0%, transparent 55%);
      pointer-events: none;
      z-index: 0;
    }

    /* --- Layout --- */
    .container {
      position: relative;
      z-index: 1;
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* --- Header --- */
    header {
      padding: 32px 0 24px;
      border-bottom: 1px solid var(--border);
    }
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .logo-icon {
      width: 46px; height: 46px;
      background: var(--gradient-1);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      box-shadow: 0 0 20px var(--accent-glow);
    }
    .logo-text h1 {
      font-size: 1.2rem;
      font-weight: 700;
      background: var(--gradient-1);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .logo-text p {
      font-size: 0.78rem;
      color: var(--text-muted);
      margin-top: 2px;
    }
    #health-badge {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 14px;
      background: var(--bg-glass);
      border: 1px solid var(--border);
      border-radius: 100px;
      font-size: 0.78rem;
      color: var(--text-secondary);
      transition: var(--transition);
    }
    #health-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--text-muted);
      transition: var(--transition);
    }
    #health-dot.ok   { background: var(--success); box-shadow: 0 0 8px var(--success); }
    #health-dot.err  { background: var(--danger);  box-shadow: 0 0 8px var(--danger); }

    /* --- Main --- */
    main { padding: 40px 0 60px; }

    /* --- Hero CTA --- */
    .hero {
      text-align: center;
      padding: 48px 0 40px;
    }
    .hero-label {
      display: inline-block;
      padding: 5px 14px;
      background: rgba(99,102,241,0.15);
      border: 1px solid rgba(99,102,241,0.35);
      border-radius: 100px;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent-light);
      margin-bottom: 20px;
    }
    .hero h2 {
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 14px;
    }
    .hero h2 span {
      background: var(--gradient-2);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero p {
      font-size: 1rem;
      color: var(--text-secondary);
      max-width: 520px;
      margin: 0 auto 32px;
      line-height: 1.65;
    }

    /* --- Forecast button --- */
    #btn-forecast {
      position: relative;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 16px 36px;
      background: var(--gradient-1);
      border: none;
      border-radius: 100px;
      font-family: 'Inter', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      color: #fff;
      cursor: pointer;
      transition: var(--transition);
      box-shadow: 0 0 30px var(--accent-glow), 0 4px 20px rgba(0,0,0,0.4);
    }
    #btn-forecast:hover { transform: translateY(-2px); box-shadow: 0 0 45px var(--accent-glow), 0 8px 25px rgba(0,0,0,0.5); }
    #btn-forecast:active { transform: translateY(0); }
    #btn-forecast:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    .btn-icon { font-size: 1.1rem; }
    .spinner {
      display: none;
      width: 18px; height: 18px;
      border: 2px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    #btn-forecast.loading .btn-icon { display: none; }
    #btn-forecast.loading .spinner  { display: block; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* --- Cards --- */
    .card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px;
      backdrop-filter: blur(12px);
      transition: border-color var(--transition);
    }
    .card:hover { border-color: var(--border-hover); }
    .card-title {
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .card-title::before {
      content: '';
      display: inline-block;
      width: 4px; height: 14px;
      background: var(--gradient-1);
      border-radius: 2px;
    }

    /* --- Error / info banner --- */
    #message-banner {
      display: none;
      padding: 14px 20px;
      border-radius: var(--radius-sm);
      font-size: 0.9rem;
      margin-bottom: 28px;
      border-left: 3px solid;
      animation: slideIn 0.3s ease;
    }
    #message-banner.error   { background: rgba(239,68,68,0.1);  border-color: var(--danger);  color: #fca5a5; }
    #message-banner.info    { background: rgba(6,182,212,0.1);  border-color: #06b6d4;        color: #67e8f9; }
    #message-banner.success { background: rgba(16,185,129,0.1); border-color: var(--success); color: #6ee7b7; }
    @keyframes slideIn { from { opacity:0; transform: translateY(-8px); } to { opacity:1; transform: none; } }

    /* --- Results section --- */
    #results-section { display: none; animation: fadeUp 0.4s ease; }
    @keyframes fadeUp { from { opacity:0; transform: translateY(16px); } to { opacity:1; transform: none; } }

    /* --- Stats row --- */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 16px;
      margin-bottom: 28px;
    }
    .stat-card {
      background: var(--bg-glass);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 18px 20px;
      text-align: center;
    }
    .stat-label { font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 6px; }
    .stat-value { font-size: 1.5rem; font-weight: 700; }
    .stat-unit  { font-size: 0.72rem; color: var(--text-secondary); margin-top: 2px; }
    .stat-card.accent .stat-value { background: var(--gradient-1); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

    /* --- Chart --- */
    .chart-wrapper {
      position: relative;
      height: 280px;
      margin-bottom: 28px;
    }

    /* --- Table --- */
    .table-wrapper { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    thead th {
      padding: 10px 14px;
      text-align: left;
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-muted);
      border-bottom: 1px solid var(--border);
    }
    tbody tr { transition: background var(--transition); }
    tbody tr:hover { background: var(--bg-glass); }
    tbody td { padding: 10px 14px; color: var(--text-secondary); border-bottom: 1px solid rgba(255,255,255,0.03); }
    td.price-cell { font-weight: 600; color: var(--text-primary); }
    td.price-cell.high  { color: #f87171; }
    td.price-cell.low   { color: #34d399; }
    td.price-cell.peak  { color: #fbbf24; }
    .hour-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 30px; height: 24px;
      background: var(--bg-glass);
      border: 1px solid var(--border);
      border-radius: 6px;
      font-weight: 600;
      font-size: 0.78rem;
      color: var(--accent-light);
    }

    /* --- Advanced section --- */
    details {
      margin-top: 40px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }
    summary {
      padding: 18px 24px;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text-secondary);
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 10px;
      user-select: none;
      list-style: none;
      background: var(--bg-card);
      transition: background var(--transition);
    }
    summary:hover { background: var(--bg-glass); color: var(--text-primary); }
    summary::marker, summary::-webkit-details-marker { display: none; }
    summary .chevron { margin-left: auto; transition: transform 0.25s; font-size: 0.8rem; }
    details[open] summary .chevron { transform: rotate(180deg); }

    .advanced-body { padding: 24px; }
    .form-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin-bottom: 20px;
    }
    .field label {
      display: block;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 6px;
    }
    .field input, .field select {
      width: 100%;
      padding: 10px 14px;
      background: var(--bg-primary);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      color: var(--text-primary);
      font-family: 'Inter', sans-serif;
      font-size: 0.875rem;
      transition: border-color var(--transition), box-shadow var(--transition);
      outline: none;
    }
    .field input:focus, .field select:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }
    .field select option { background: var(--bg-secondary); }
    #btn-manual {
      padding: 11px 28px;
      background: var(--bg-glass);
      border: 1px solid var(--accent);
      border-radius: 100px;
      color: var(--accent-light);
      font-family: 'Inter', sans-serif;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
    }
    #btn-manual:hover { background: rgba(99,102,241,0.15); }
    #manual-result {
      display: none;
      margin-top: 16px;
      padding: 16px 20px;
      background: rgba(99,102,241,0.1);
      border: 1px solid rgba(99,102,241,0.3);
      border-radius: var(--radius-sm);
    }
    #manual-result .result-label { font-size: 0.75rem; color: var(--text-muted); margin-bottom: 4px; }
    #manual-result .result-value { font-size: 1.6rem; font-weight: 700; background: var(--gradient-1); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

    /* --- Footer --- */
    footer {
      border-top: 1px solid var(--border);
      padding: 24px 0;
      text-align: center;
      font-size: 0.78rem;
      color: var(--text-muted);
    }
    footer a { color: var(--accent-light); text-decoration: none; }

    /* --- Responsive --- */
    @media (max-width: 640px) {
      .stats-row { grid-template-columns: 1fr 1fr; }
      .hero { padding: 32px 0 28px; }
    }

    /* === FINALNY FRONTEND: czysty hero + spójna stylistyka MLOps === */
    header { display: none !important; }

    main {
      padding: 18px 0 60px;
    }

    .hero {
      position: relative;
      max-width: 900px;
      margin: 0 auto;
      padding: 30px 0 38px;
      text-align: center;
    }

    .hero::before {
      content: '';
      position: absolute;
      left: 50%; top: 0;
      transform: translateX(-50%);
      width: min(720px, 92vw);
      height: 250px;
      background: radial-gradient(ellipse 70% 55% at 50% 25%, rgba(99,102,241,0.16), transparent 68%);
      pointer-events: none;
      z-index: -1;
    }

    .hero-label { display: none !important; }

    .hero h2 {
      font-size: clamp(2.35rem, 5.2vw, 3.8rem);
      line-height: 1.04;
      margin: 0 0 16px;
      letter-spacing: -0.045em;
      text-shadow: 0 18px 45px rgba(0,0,0,.38);
    }

    .owner-banner {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin: 2px auto 22px;
      padding: 12px 24px;
      min-height: 48px;
      border-radius: 999px;
      background:
        linear-gradient(135deg, rgba(99,102,241,.22), rgba(6,182,212,.10)),
        rgba(255,255,255,.035);
      border: 1px solid rgba(129,140,248,.42);
      color: #dbeafe;
      font-size: clamp(.96rem, 1.8vw, 1.12rem);
      font-weight: 600;
      letter-spacing: .01em;
      box-shadow: 0 0 35px rgba(99,102,241,.14), inset 0 1px 0 rgba(255,255,255,.08);
      backdrop-filter: blur(12px);
    }

    .owner-banner::before {
      content: '⚙️';
      font-size: 1rem;
      filter: drop-shadow(0 0 8px rgba(129,140,248,.5));
    }

    .hero p {
      max-width: 650px;
      font-size: 1.05rem;
      line-height: 1.72;
      margin: 0 auto 34px;
      color: var(--text-secondary);
    }

    .hero-actions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 18px;
      flex-wrap: wrap;
      margin-top: 8px;
    }

    #btn-forecast,
    .architecture-link {
      min-height: 56px;
      border-radius: 999px;
      font-family: 'Inter', sans-serif;
      font-size: 1rem;
      font-weight: 650;
      text-decoration: none;
      transition: var(--transition);
      white-space: nowrap;
    }

    #btn-forecast {
      padding: 16px 38px;
      border: 1px solid rgba(255,255,255,.08);
    }

    .architecture-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 16px 32px;
      color: #a5f3fc;
      background:
        linear-gradient(135deg, rgba(6,182,212,.13), rgba(99,102,241,.12)),
        rgba(255,255,255,.035);
      border: 1px solid rgba(34,211,238,.55);
      box-shadow: 0 0 28px rgba(34,211,238,.08), inset 0 1px 0 rgba(255,255,255,.08);
      backdrop-filter: blur(12px);
    }

    .architecture-link::before {
      content: '🧭';
      font-size: 1.05rem;
    }

    .architecture-link:hover {
      color: #ecfeff;
      border-color: rgba(103,232,249,.9);
      background:
        linear-gradient(135deg, rgba(6,182,212,.22), rgba(99,102,241,.18)),
        rgba(255,255,255,.055);
      transform: translateY(-2px);
      box-shadow: 0 0 36px rgba(34,211,238,.16), 0 8px 25px rgba(0,0,0,.35);
    }

    .stats-row { margin-top: 0; }

    @media (max-width: 700px) {
      main { padding-top: 8px; }
      .hero { padding: 24px 0 30px; }
      .hero h2 { font-size: 2.3rem; }
      .hero p { font-size: .98rem; }
      .hero-actions { gap: 14px; }
      #btn-forecast,
      .architecture-link { width: 100%; max-width: 380px; }
      .owner-banner { border-radius: 18px; }
    }

  

    /* === WERSJA NIEBIESKA Z PORTRETEM — bez ikon, jednolita stylistyka === */
    :root {
      --bg-primary: #071225;
      --bg-secondary: #0b1b34;
      --bg-card: rgba(13, 35, 65, 0.72);
      --bg-glass: rgba(22, 54, 94, 0.52);
      --border: rgba(120, 170, 230, 0.18);
      --border-hover: rgba(93, 173, 255, 0.55);
      --accent: #2563eb;
      --accent-light: #60a5fa;
      --accent-glow: rgba(37, 99, 235, 0.28);
      --text-primary: #eef6ff;
      --text-secondary: #a8bdd7;
      --text-muted: #6f86a6;
      --gradient-1: linear-gradient(135deg, #1d4ed8, #2563eb, #38bdf8);
      --gradient-2: linear-gradient(135deg, #7dd3fc, #3b82f6);
    }

    body::before {
      background:
        radial-gradient(ellipse 80% 60% at 12% -12%, rgba(56,189,248,0.13) 0%, transparent 62%),
        radial-gradient(ellipse 65% 55% at 86% 8%, rgba(37,99,235,0.14) 0%, transparent 56%),
        linear-gradient(180deg, rgba(7,18,37,1) 0%, rgba(6,15,31,1) 100%);
    }

    header { display: none !important; }

    main { padding: 26px 0 60px; }

    .hero,
    .hero-blue-photo {
      max-width: 1040px;
      margin: 0 auto 34px;
      padding: 34px 36px;
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) 300px;
      align-items: center;
      gap: 38px;
      text-align: left;
      background:
        linear-gradient(135deg, rgba(13,35,65,0.72), rgba(9,25,50,0.46)),
        rgba(255,255,255,0.015);
      border: 1px solid rgba(96,165,250,0.20);
      border-radius: 26px;
      box-shadow: 0 30px 80px rgba(0,0,0,.34), inset 0 1px 0 rgba(255,255,255,.06);
      backdrop-filter: blur(14px);
    }

    .hero::before { display: none !important; }

    .hero-copy { min-width: 0; }

    .system-label {
      display: inline-flex;
      align-items: center;
      min-height: 34px;
      padding: 7px 14px;
      margin-bottom: 18px;
      border-radius: 999px;
      background: rgba(96,165,250,.10);
      border: 1px solid rgba(96,165,250,.24);
      color: #bfdbfe;
      font-size: .78rem;
      font-weight: 650;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    .hero h2 {
      max-width: 640px;
      font-size: clamp(2.8rem, 5.4vw, 4.65rem);
      line-height: .98;
      margin: 0 0 18px;
      letter-spacing: -0.055em;
      color: #f8fbff;
      text-shadow: 0 20px 55px rgba(0,0,0,.34);
    }

    .owner-banner {
      display: inline-flex;
      align-items: center;
      justify-content: flex-start;
      margin: 0 0 26px;
      padding: 13px 18px;
      min-height: 46px;
      border-radius: 14px;
      background: rgba(37,99,235,.18);
      border: 1px solid rgba(96,165,250,.34);
      color: #e5f1ff;
      font-size: clamp(.95rem, 1.6vw, 1.08rem);
      font-weight: 600;
      letter-spacing: .005em;
      box-shadow: none;
      backdrop-filter: blur(12px);
    }

    .owner-banner::before,
    .architecture-link::before { content: none !important; display: none !important; }

    .hero p { display: none !important; }

    .hero-actions {
      justify-content: flex-start;
      gap: 14px;
      margin-top: 0;
    }

    #btn-forecast,
    .architecture-link {
      min-height: 54px;
      border-radius: 14px;
      font-family: 'Inter', system-ui, sans-serif;
      font-size: .98rem;
      font-weight: 650;
      letter-spacing: .005em;
      box-shadow: none;
      white-space: normal;
    }

    #btn-forecast {
      padding: 15px 28px;
      color: #ffffff;
      background: linear-gradient(135deg, #1d4ed8, #2563eb);
      border: 1px solid rgba(147,197,253,.30);
    }

    #btn-forecast:hover {
      transform: translateY(-2px);
      background: linear-gradient(135deg, #2563eb, #3b82f6);
      box-shadow: 0 18px 34px rgba(37,99,235,.22);
    }

    .architecture-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 15px 24px;
      color: #dbeafe;
      background: rgba(30,64,120,.42);
      border: 1px solid rgba(96,165,250,.34);
    }

    .architecture-link:hover {
      color: #ffffff;
      border-color: rgba(147,197,253,.62);
      background: rgba(37,99,235,.28);
      transform: translateY(-2px);
      box-shadow: 0 18px 34px rgba(37,99,235,.14);
    }

    .btn-icon { display: none !important; }

    .author-card {
      width: 100%;
      padding: 18px;
      border-radius: 22px;
      background: rgba(5, 15, 31, .55);
      border: 1px solid rgba(96,165,250,.22);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
      text-align: center;
    }

    .author-photo-wrap {
      width: 100%;
      aspect-ratio: 1 / 1;
      overflow: hidden;
      border-radius: 18px;
      background: #eaf2fb;
      border: 1px solid rgba(147,197,253,.28);
    }

    .author-photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: 50% 18%;
      display: block;
    }

    .author-name {
      margin-top: 14px;
      color: #f8fbff;
      font-weight: 700;
      font-size: 1rem;
    }

    .author-role {
      margin-top: 5px;
      color: var(--text-secondary);
      font-size: .78rem;
      line-height: 1.45;
    }

    .card,
    .stat-card,
    details {
      background: rgba(12, 30, 57, .72);
      border-color: rgba(96,165,250,.16);
    }

    .card:hover { border-color: rgba(96,165,250,.34); }
    .card-title::before { background: #3b82f6; }
    .stat-card.accent .stat-value { background: var(--gradient-2); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

    @media (max-width: 860px) {
      .hero,
      .hero-blue-photo {
        grid-template-columns: 1fr;
        text-align: center;
        padding: 28px 22px;
      }
      .hero-actions { justify-content: center; }
      .owner-banner { justify-content: center; }
      .author-card { max-width: 300px; margin: 0 auto; }
    }

    @media (max-width: 640px) {
      main { padding-top: 12px; }
      .hero h2 { font-size: 2.45rem; }
      .system-label { font-size: .72rem; }
      #btn-forecast,
      .architecture-link { width: 100%; max-width: none; }
    }

  </style>
</head>
<body>


<main>
  <div class="container">

    <!-- Hero -->
    <section class="hero hero-blue-photo">
      <div class="hero-copy">
        <div class="system-label">System demonstracyjny MLOps</div>
        <h2>Prognoza cen energii</h2>
        <div class="owner-banner">Wojciech Moszczyński · demonstracyjny system MLOps</div>
        <div class="hero-actions">
          <button id="btn-forecast">
            <div class="spinner"></div>
            <span class="btn-text">Prognoza na jutro</span>
          </button>
          <a class="architecture-link" href="/architecture.html">Zobacz schemat systemu MLOps</a>
        </div>
      </div>
      <aside class="author-card" aria-label="Autor systemu">
        <div class="author-photo-wrap">
          <img class="author-photo" src="data:image/jpeg;base64," alt="Wojciech Moszczyński" />
        </div>
        <div class="author-name">Wojciech Moszczyński</div>
        <div class="author-role">MLOps · ML Engineering · system produkcyjny</div>
      </aside>
    </section>

    <!-- Message banner -->
    <div id="message-banner" role="alert"></div>

    <!-- Results -->
    <section id="results-section">

      <div class="stats-row" id="stats-row"></div>

      <div class="card" style="margin-bottom:24px;">
        <div class="card-title">Profil dobowy cen RDN [PLN/MWh]</div>
        <div class="chart-wrapper">
          <canvas id="price-chart"></canvas>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Prognozy godzinowe</div>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Godz.</th>
                <th>Cena [PLN/MWh]</th>
                <th>Temp [°C]</th>
                <th>Wiatr [km/h]</th>
                <th>Nasl. [W/m²]</th>
                <th>Dzień</th>
              </tr>
            </thead>
            <tbody id="forecast-tbody"></tbody>
          </table>
        </div>
      </div>

    </section>

    <!-- Advanced mode -->
    <details id="advanced-details">
      <summary>
        🔧 Tryb zaawansowany — ręczne wpisanie cech
        <span class="chevron">▼</span>
      </summary>
      <div class="advanced-body">
        <p style="font-size:0.85rem;color:var(--text-secondary);margin-bottom:20px;">
          Wpisz wartości 8 cech wejściowych, aby uzyskać predykcję dla dowolnego scenariusza.
        </p>
        <div class="form-grid">
          <div class="field">
            <label for="f-hour">Godzina (0–23)</label>
            <input type="number" id="f-hour" min="0" max="23" value="14" />
          </div>
          <div class="field">
            <label for="f-dow">Dzień tygodnia</label>
            <select id="f-dow">
              <option value="0">Poniedziałek</option>
              <option value="1">Wtorek</option>
              <option value="2">Środa (wybrana)</option>
              <option value="3">Czwartek</option>
              <option value="4">Piątek</option>
              <option value="5">Sobota</option>
              <option value="6">Niedziela</option>
            </select>
          </div>
          <div class="field">
            <label for="f-holiday">Weekend / Święto</label>
            <select id="f-holiday">
              <option value="0">Nie (dzień roboczy)</option>
              <option value="1">Tak (weekend/święto)</option>
            </select>
          </div>
          <div class="field">
            <label for="f-temp">Temp. krajowa [°C]</label>
            <input type="number" id="f-temp" step="0.1" value="15.3" />
          </div>
          <div class="field">
            <label for="f-wind">Wiatr [km/h]</label>
            <input type="number" id="f-wind" step="0.1" min="0" value="12.5" />
          </div>
          <div class="field">
            <label for="f-rad">Nasłonecznienie [W/m²]</label>
            <input type="number" id="f-rad" step="1" min="0" value="320" />
          </div>
          <div class="field">
            <label for="f-lag24">Cena lag 24h [PLN/MWh]</label>
            <input type="number" id="f-lag24" step="0.01" value="285.50" />
          </div>
          <div class="field">
            <label for="f-lag168">Cena lag 168h [PLN/MWh]</label>
            <input type="number" id="f-lag168" step="0.01" value="271.30" />
          </div>
        </div>
        <button id="btn-manual">Oblicz predykcję</button>
        <div id="manual-result">
          <div class="result-label">Prognozowana cena RDN</div>
          <div class="result-value" id="manual-result-value"></div>
        </div>
        <div id="manual-error" style="display:none;color:#f87171;font-size:0.85rem;margin-top:12px;"></div>
      </div>
    </details>

  </div>
</main>

<footer>
  <div class="container">
    Dane: <a href="https://api.raporty.pse.pl" target="_blank" rel="noopener">PSE API</a> ·
    <a href="https://open-meteo.com" target="_blank" rel="noopener">Open-Meteo</a> ·
    Model: sklearn pipeline · Prognoza dla Rynku Dnia Następnego (SDAC)
  </div>
</footer>

<script>
/* =========================================================
   EnergyForecast PL — Frontend Logic
   ========================================================= */

const API_BASE = '';   // ten sam origin — bez CORS

// ---- DOM refs ---------------------------------------------------------------
const btnForecast   = document.getElementById('btn-forecast');
const banner        = document.getElementById('message-banner');
const resultsSection= document.getElementById('results-section');
const statsRow      = document.getElementById('stats-row');
const tbody         = document.getElementById('forecast-tbody');
const healthDot     = document.getElementById('health-dot');
const healthText    = document.getElementById('health-text');
const btnManual     = document.getElementById('btn-manual');
const manualResult  = document.getElementById('manual-result');
const manualResultVal = document.getElementById('manual-result-value');
const manualError   = document.getElementById('manual-error');

let chartInstance = null;

// ---- Health check -----------------------------------------------------------
async function checkHealth() {
  // Górny pasek statusu został usunięty z widoku. Funkcja zostaje tylko jako bezpieczny fallback.
  if (!healthDot || !healthText) return;
  try {
    const r = await fetch(`${API_BASE}/health`);
    const data = await r.json();
    if (data.model_loaded) {
      healthDot.className = 'ok';
      healthText.textContent = `Model gotowy · sklearn ${data.sklearn_version || ''}`;
    } else {
      healthDot.className = 'err';
      healthText.textContent = 'Model nie załadowany';
    }
  } catch {
    healthDot.className = 'err';
    healthText.textContent = 'API niedostępne';
  }
}

// ---- Banner helper ----------------------------------------------------------
function showBanner(msg, type = 'error') {
  banner.textContent = msg;
  banner.className = type;
  banner.style.display = 'block';
  banner.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}
function hideBanner() { banner.style.display = 'none'; }

// ---- Chart ------------------------------------------------------------------
function buildChart(labels, prices) {
  const ctx = document.getElementById('price-chart').getContext('2d');
  if (chartInstance) chartInstance.destroy();

  const grad = ctx.createLinearGradient(0, 0, 0, 280);
  grad.addColorStop(0, 'rgba(99,102,241,0.35)');
  grad.addColorStop(1, 'rgba(99,102,241,0)');

  chartInstance = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [{
        label: 'Prognozowana cena [PLN/MWh]',
        data: prices,
        borderColor: '#6366f1',
        backgroundColor: grad,
        borderWidth: 2.5,
        pointRadius: 4,
        pointHoverRadius: 7,
        pointBackgroundColor: '#818cf8',
        pointBorderColor: '#0a0e1a',
        pointBorderWidth: 2,
        fill: true,
        tension: 0.4,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: 'rgba(17,24,39,0.95)',
          borderColor: 'rgba(99,102,241,0.4)',
          borderWidth: 1,
          titleColor: '#f1f5f9',
          bodyColor: '#94a3b8',
          padding: 12,
          callbacks: {
            label: ctx => ` ${ctx.parsed.y.toFixed(2)} PLN/MWh`,
          }
        }
      },
      scales: {
        x: {
          grid: { color: 'rgba(255,255,255,0.04)' },
          ticks: { color: '#475569', font: { size: 11 } },
        },
        y: {
          grid: { color: 'rgba(255,255,255,0.05)' },
          ticks: {
            color: '#475569',
            font: { size: 11 },
            callback: v => v.toFixed(0),
          }
        }
      }
    }
  });
}

// ---- Price color class ------------------------------------------------------
function priceClass(price, min, max, avg) {
  if (price === max) return 'peak';
  if (price > avg * 1.15) return 'high';
  if (price < avg * 0.85) return 'low';
  return '';
}

// ---- Stats row --------------------------------------------------------------
function renderStats(forecasts, date) {
  const prices = forecasts.map(f => f.predicted_price_pln);
  const avg  = prices.reduce((a,b)=>a+b,0) / prices.length;
  const min  = Math.min(...prices);
  const max  = Math.max(...prices);
  const peak = forecasts.find(f => f.predicted_price_pln === max);

  const dayNames = ['Pon','Wt','Śr','Czw','Pt','Sob','Ndz'];
  const d = new Date(date + 'T00:00:00');
  const dateLabel = `${dayNames[d.getDay()==0?6:d.getDay()-1]} ${d.getDate()}.${String(d.getMonth()+1).padStart(2,'0')}`;

  statsRow.innerHTML = `
    <div class="stat-card accent">
      <div class="stat-label">Średnia cena</div>
      <div class="stat-value">${avg.toFixed(1)}</div>
      <div class="stat-unit">PLN/MWh</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Minimum</div>
      <div class="stat-value" style="color:#34d399">${min.toFixed(1)}</div>
      <div class="stat-unit">PLN/MWh</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Maksimum</div>
      <div class="stat-value" style="color:#f87171">${max.toFixed(1)}</div>
      <div class="stat-unit">PLN/MWh</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Godzina peak</div>
      <div class="stat-value" style="color:#fbbf24">${String(peak.hour).padStart(2,'0')}:00</div>
      <div class="stat-unit">${dateLabel}</div>
    </div>
  `;
}

// ---- Table row --------------------------------------------------------------
function renderTable(forecasts) {
  const prices = forecasts.map(f => f.predicted_price_pln);
  const avg  = prices.reduce((a,b)=>a+b,0) / prices.length;
  const max  = Math.max(...prices);
  const holidayLabel = f => f.is_holiday_or_weekend ? 'Weekend/Święto' : 'Roboczy';

  tbody.innerHTML = forecasts.map(f => {
    const cls = priceClass(f.predicted_price_pln, Math.min(...prices), max, avg);
    return `<tr>
      <td><span class="hour-badge">${String(f.hour).padStart(2,'0')}</span></td>
      <td class="price-cell ${cls}">${f.predicted_price_pln.toFixed(2)}</td>
      <td>${f.temp_pl.toFixed(1)}</td>
      <td>${f.wind_pl.toFixed(1)}</td>
      <td>${f.radiation_pl.toFixed(0)}</td>
      <td style="color:var(--text-muted);font-size:0.8rem">${holidayLabel(f)}</td>
    </tr>`;
  }).join('');
}

// ---- Main forecast action ---------------------------------------------------
async function runForecast() {
  hideBanner();
  btnForecast.disabled = true;
  btnForecast.classList.add('loading');
  const oldIcon = btnForecast.querySelector('.btn-icon');
  if (oldIcon) oldIcon.textContent = '';

  try {
    const r = await fetch(`${API_BASE}/predict/next-day`);
    const data = await r.json();

    if (!r.ok) {
      showBanner(`❌ Błąd API (${r.status}): ${data.detail || 'Nieznany błąd'}`, 'error');
      return;
    }

    const { forecasts, date } = data;

    // Render
    renderStats(forecasts, date);
    const labels = forecasts.map(f => `${String(f.hour).padStart(2,'0')}:00`);
    const prices = forecasts.map(f => f.predicted_price_pln);
    buildChart(labels, prices);
    renderTable(forecasts);

    resultsSection.style.display = 'block';
    resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });

    showBanner(
      `✅ Prognoza na ${date} wygenerowana — ${forecasts.length} godzin`,
      'success'
    );
    setTimeout(hideBanner, 4000);

  } catch (e) {
    showBanner(`❌ Nie można połączyć się z API: ${e.message}`, 'error');
  } finally {
    btnForecast.disabled = false;
    btnForecast.classList.remove('loading');
  }
}

// ---- Manual predict ---------------------------------------------------------
async function runManual() {
  manualError.style.display = 'none';
  manualResult.style.display = 'none';

  const payload = {
    hour:                  parseInt(document.getElementById('f-hour').value),
    day_of_week:           parseInt(document.getElementById('f-dow').value),
    is_holiday_or_weekend: parseInt(document.getElementById('f-holiday').value),
    temp_pl:               parseFloat(document.getElementById('f-temp').value),
    wind_pl:               parseFloat(document.getElementById('f-wind').value),
    radiation_pl:          parseFloat(document.getElementById('f-rad').value),
    price_lag_24h:         parseFloat(document.getElementById('f-lag24').value),
    price_lag_168h:        parseFloat(document.getElementById('f-lag168').value),
  };

  try {
    const r = await fetch(`${API_BASE}/predict`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const data = await r.json();
    if (!r.ok) {
      manualError.textContent = `Błąd (${r.status}): ${JSON.stringify(data.detail || data)}`;
      manualError.style.display = 'block';
      return;
    }
    manualResultVal.textContent = `${data.prediction.toFixed(2)} PLN/MWh`;
    manualResult.style.display = 'block';
  } catch(e) {
    manualError.textContent = `Błąd połączenia: ${e.message}`;
    manualError.style.display = 'block';
  }
}

// ---- Init -------------------------------------------------------------------
btnForecast.addEventListener('click', runForecast);
btnManual.addEventListener('click', runManual);
checkHealth();
setInterval(checkHealth, 30000);
</script>
</body>
</html>
